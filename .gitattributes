# Normalize line endings to LF on commit; check out native on each platform.
# Prevents CRLF/LF churn (e.g. from editors on Windows/WSL).
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
